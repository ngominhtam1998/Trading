# ============================================================
# Trading Bot - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# === BOT MODE ===
# testnet = Binance Futures Testnet (fake money, START HERE)
# dry     = Real market data, NO real orders (paper trading)
# live    = Real money on Binance Futures mainnet
BOT_MODE=testnet

# === STRATEGY LEVEL ===
# v6_3m = 3m monitoring (avg +1592%, WR 64%, dip -5%) → uses lv4 account
# v6_1m = 1m monitoring (avg +660%, WR 73%, dip -2%)  → uses lv5 account
BOT_STRATEGY=v6_3m

# === BINANCE API KEYS ===
# Testnet: get from https://testnet.binancefuture.com (login -> API Key)
# Live:    get from https://www.binance.com (Account -> API Management)
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=
BINANCE_LIVE_KEY=
BINANCE_LIVE_SECRET=

# === TELEGRAM NOTIFICATIONS (optional) ===
# 1. Chat with @BotFather -> /newbot -> get token
# 2. Create channels, add bot as admin to each
# 3. Set chat_id for each strategy level you use
#    (channel username like @Trading_LV1 OR numeric -1001234567890)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_LV1=@Trading_LV1
TELEGRAM_CHAT_LV2=@Trading_LV2
TELEGRAM_CHAT_LV3=@Trading_LV3
TELEGRAM_CHAT_LV4=@Trading_LV4
TELEGRAM_CHAT_LV5=@Trading_LV5
TELEGRAM_CHAT_LV6=@Trading_LV6
